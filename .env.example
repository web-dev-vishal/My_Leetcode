PORT=8080
MONGODB_URI="mongodb://localhost:27017/leetcode"
JWT_SECRET="your-secret-key-here"

# CORS Configuration
CORS_ORIGIN="*"

# Redis Configuration
REDIS_HOST="localhost"
REDIS_PORT="6379"
REDIS_PASSWORD="your-redis-password"

# RabbitMQ Configuration
RABBITMQ_URL="amqp://admin:password@localhost:5672"

# Judge0 Configuration
RAPIDAPI_KEY="your-rapidapi-key"
RAPIDAPI_HOST="judge0-ce.p.rapidapi.com"
JUDGE0_API_URL="https://judge0-ce.p.rapidapi.com"

# OpenRouter AI Configuration
OPENROUTER_API_KEY="your-openrouter-api-key"
OPENROUTER_BASE_URL="https://openrouter.ai/api/v1"
OPENROUTER_MODEL="google/gemini-flash-1.5"
OPENROUTER_TIMEOUT=30000
APP_URL="http://localhost:8080"

# Public API Integration Configuration

# Weather API (OpenWeatherMap - Free tier: 60 calls/min, 1M calls/month)
# Get FREE API key at: https://openweathermap.org/api
WEATHER_API_KEY="your-weather-api-key"
WEATHER_API_BASE_URL="https://api.openweathermap.org/data/2.5"
WEATHER_API_TIMEOUT=10000
WEATHER_API_CACHE_TTL=600
WEATHER_API_RATE_LIMIT_MAX=60
WEATHER_API_RATE_LIMIT_WINDOW=60

# Finance API (Alpha Vantage - Free tier: 25 calls/day)
# Get FREE API key at: https://www.alphavantage.co/support/#api-key
FINANCE_API_KEY="your-finance-api-key"
FINANCE_API_BASE_URL="https://www.alphavantage.co/query"
FINANCE_API_TIMEOUT=10000
FINANCE_API_CACHE_TTL=60
FINANCE_API_RATE_LIMIT_MAX=5
FINANCE_API_RATE_LIMIT_WINDOW=60

# News API (NewsAPI - Free tier: 100 calls/day)
# Get FREE API key at: https://newsapi.org/register
NEWS_API_KEY="your-news-api-key"
NEWS_API_BASE_URL="https://newsapi.org/v2"
NEWS_API_TIMEOUT=10000
NEWS_API_CACHE_TTL=900
NEWS_API_RATE_LIMIT_MAX=100
NEWS_API_RATE_LIMIT_WINDOW=86400
